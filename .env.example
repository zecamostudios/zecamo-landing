# ============================================================
# zecamo-landing — Variables de Entorno
# Copiar este archivo como .env.local y completar los valores.
# NUNCA commitear .env.local
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Obtener desde: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SOLO en servidor, NUNCA en cliente (NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── RESEND (email transaccional) ──────────────────────────────
# Obtener desde: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente (debe ser un dominio verificado en Resend)
RESEND_FROM_EMAIL=hola@zecamostudios.com

# Email destino para notificaciones de nuevos leads
RESEND_TO_EMAIL=joaquincajal85@gmail.com

# ── DATOS LEGALES PÚBLICOS (footer) ──────────────────────────
# No son secretos, pueden empezar con NEXT_PUBLIC_.
NEXT_PUBLIC_COMPANY_NAME=Zecamo Studios
NEXT_PUBLIC_COMPANY_LEGAL_NAME=Zecamo Studios S.A.S.
NEXT_PUBLIC_COMPANY_TAX_ID=En trámite
NEXT_PUBLIC_COMPANY_ADDRESS=Tucumán, Argentina
NEXT_PUBLIC_COMPANY_LOCATION=Tucumán, Argentina
NEXT_PUBLIC_COMPANY_EMAIL=hola@zecamostudios.com
NEXT_PUBLIC_SITE_URL=https://zecamostudios.com

# ── REDES SOCIALES ────────────────────────────────────────────
# Usar '#' mientras no esté disponible el perfil (muestra estado deshabilitado)
NEXT_PUBLIC_SOCIAL_INSTAGRAM=#
NEXT_PUBLIC_SOCIAL_LINKEDIN=#
NEXT_PUBLIC_SOCIAL_X=#
NEXT_PUBLIC_SOCIAL_FACEBOOK=#

# ── NEXT.JS ──────────────────────────────────────────────────
# En producción, Vercel lo setea automáticamente.
# Solo necesario si hacés deploys fuera de Vercel.
# NEXT_PUBLIC_VERCEL_URL=
